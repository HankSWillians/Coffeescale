# CoffeeScale Backend — Environment Variables
# Copy this to .env and fill in values. NEVER commit .env

# HMAC secret shared with IoT devices (also stored in Parameter Store)
HMAC_SECRET=change-me-super-secret-32-chars-minimum

# ERP LogisCore endpoint
ERP_URL=https://erp.coffeescale.local/orders

# Notification email for store managers
NOTIFICATION_EMAIL=gerente@andinaroasters.co

# AWS region (default us-east-1 per ADR-002)
AWS_DEFAULT_REGION=us-east-1

# Stack name used by SAM deploy
STACK_NAME=coffeescale-prod
